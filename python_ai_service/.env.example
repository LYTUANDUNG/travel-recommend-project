# BẢO MẬT API KEY (KHÔNG ĐƯA FILE .env LÊN GITHUB)
# Sửa tên file này thành `.env` để sử dụng cho enrich_images.py

# Cấu hình Database MySQL
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASS=root
DB_NAME=travel_recommendation

# Cấu hình Cloudinary (Lấy trong application.yml của Java Backend)
CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME
